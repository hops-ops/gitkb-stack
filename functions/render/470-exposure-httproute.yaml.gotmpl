# code: language=yaml
#
# Optional unauthenticated Gateway API HTTPRoute for GitKB sync traffic.
# ExternalDNS integration is annotation-based and intentionally lives on the
# HTTPRoute so DNS follows the route domain.

{{- $exp := $state.exposure }}
{{- $dns := $exp.dns }}

{{- if and $exp.enabled $exp.domain $exp.gatewayRef.name }}
---
apiVersion: kubernetes.m.crossplane.io/v1alpha1
kind: Object
metadata:
  name: {{ $state.name }}-exposure-httproute
  annotations:
    {{ setResourceNameAnnotation "exposure-httproute" }}
  labels: {{ $state.labels | toJson }}
spec:
  managementPolicies: {{ $state.managementPolicies | toJson }}
  forProvider:
    manifest:
      apiVersion: gateway.networking.k8s.io/v1
      kind: HTTPRoute
      metadata:
        name: {{ $state.releaseName }}
        namespace: {{ $state.namespace }}
        labels: {{ $state.labels | toJson }}
        {{- if $dns.enabled }}
        annotations:
          external-dns.alpha.kubernetes.io/hostname: {{ $exp.domain | quote }}
          {{- if $dns.target }}
          external-dns.alpha.kubernetes.io/target: {{ $dns.target | quote }}
          {{- end }}
          {{- if $dns.ttl }}
          external-dns.alpha.kubernetes.io/ttl: {{ $dns.ttl | quote }}
          {{- end }}
          {{- with $dns.annotations }}
          {{- toYaml . | nindent 10 }}
          {{- end }}
        {{- end }}
      spec:
        parentRefs:
        - name: {{ $exp.gatewayRef.name }}
          {{- if $exp.gatewayRef.namespace }}
          namespace: {{ $exp.gatewayRef.namespace }}
          {{- end }}
          {{- if $exp.gatewayRef.sectionName }}
          sectionName: {{ $exp.gatewayRef.sectionName }}
          {{- end }}
        hostnames:
        - {{ $exp.domain | quote }}
        rules:
        - matches:
          - path:
              type: PathPrefix
              value: {{ $exp.pathPrefix | quote }}
          {{- if ne $exp.pathPrefix "/" }}
          filters:
          - type: URLRewrite
            urlRewrite:
              path:
                type: ReplacePrefixMatch
                replacePrefixMatch: /
          {{- end }}
          backendRefs:
          - name: {{ $exp.serviceName }}
            namespace: {{ $state.namespace }}
            port: {{ $state.server.port }}
  providerConfigRef:
    name: {{ $state.kubernetesProviderConfigRef.name }}
    kind: {{ $state.kubernetesProviderConfigRef.kind }}
{{- end }}

{{- if and $exp.enabled $exp.domain $exp.gatewayRef.name $state.observed.release.ready $state.observed.exposure.routeReady }}
---
apiVersion: protection.crossplane.io/v1beta1
kind: Usage
metadata:
  name: {{ $state.name }}-delete-httproute-before-gitkb
  annotations:
    {{ setResourceNameAnnotation "usage-httproute-gitkb" }}
  labels: {{ $state.labels | toJson }}
spec:
  replayDeletion: true
  of:
    apiVersion: helm.m.crossplane.io/v1beta1
    kind: Release
    resourceRef:
      name: {{ $state.releaseName }}
  by:
    apiVersion: kubernetes.m.crossplane.io/v1alpha1
    kind: Object
    resourceRef:
      name: {{ $state.name }}-exposure-httproute
{{- end }}

{{- if and $exp.enabled $exp.domain $exp.gatewayRef.name $state.observed.namespace.ready $state.observed.exposure.routeReady }}
---
apiVersion: protection.crossplane.io/v1beta1
kind: Usage
metadata:
  name: {{ $state.name }}-delete-httproute-before-namespace
  annotations:
    {{ setResourceNameAnnotation "usage-httproute-namespace" }}
  labels: {{ $state.labels | toJson }}
spec:
  replayDeletion: true
  of:
    apiVersion: kubernetes.m.crossplane.io/v1alpha1
    kind: Object
    resourceRef:
      name: {{ $state.name }}-namespace
  by:
    apiVersion: kubernetes.m.crossplane.io/v1alpha1
    kind: Object
    resourceRef:
      name: {{ $state.name }}-exposure-httproute
{{- end }}
